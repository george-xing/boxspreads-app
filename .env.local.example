# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase service-role key. Bypasses Row Level Security.
# REQUIRED for /api/schwab/* — do NOT prefix with NEXT_PUBLIC_ and never
# expose to the browser bundle. Get it from Supabase project settings →
# API → "service_role" key.
SUPABASE_SERVICE_ROLE_KEY=

# 32 raw bytes, base64-encoded. Used to AES-256-GCM encrypt Schwab
# refresh tokens at rest in `schwab_connections.refresh_token`.
# Generate with:
#   openssl rand -base64 32
# Rotate by adding a new key and bumping CURRENT_KEY_VERSION in
# src/lib/schwab/refresh-token-crypto.ts.
REFRESH_TOKEN_KMS_KEY=

# FRED (existing)
FRED_API_KEY=your-fred-api-key

# Schwab API (get from developer.schwab.com)
SCHWAB_APP_KEY=
SCHWAB_APP_SECRET=
SCHWAB_REFRESH_TOKEN=

# Session cookie signing (≥32 random chars)
SESSION_SECRET=

# Admin login key for Phase 1 George access (any strong passphrase)
ADMIN_KEY=
